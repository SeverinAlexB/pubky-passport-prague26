# Google OAuth 2.0 Web Client ID (same value on client and server).
# Public on the client, kept consistent on the server for JWT audience check.

# ---------------------------------------------------------------------------
# Wrapping-key derivation backend: set ONE of the below.
# If both are set, GCP_KMS_MAC_KEY wins.
# ---------------------------------------------------------------------------

# --- Mode A: Cloud HSM (recommended for prod) ---
# Full resource path of a Cloud KMS MAC key version (HMAC_SHA256, HSM protection).
# The service account running this server needs roles/cloudkms.signerVerifier
# on this key. Credentials are picked up via Application Default Credentials.
# GCP_KMS_MAC_KEY=projects/PROJECT/locations/LOC/keyRings/RING/cryptoKeys/KEY/cryptoKeyVersions/1

# --- Mode B: Local HKDF (dev / single-instance) ---
# High-entropy server secret used as IKM for HKDF.
# Generate with: openssl rand -base64 48
SERVER_SECRET=replace-with-random-bytes

# ---------------------------------------------------------------------------
# Pubky
# ---------------------------------------------------------------------------

# Default homeserver (z32 public key) used when a signin deeplink arrives for
# a pubky that has never been registered. Signup deeplinks override this with
# their own homeserver. Defaults to Synonym's production homeserver.
#   Production: 8um71us3fyw6h8wbcxb5ar3rwusy1a6u49956ikzojg3gcwd1dty
#   Staging:    ufibwbmed6jeq9k4p583go95wofakh9fwpp4k734trq79pd9u1uy
# NEXT_PUBLIC_DEFAULT_HOMESERVER=8um71us3fyw6h8wbcxb5ar3rwusy1a6u49956ikzojg3gcwd1dty
